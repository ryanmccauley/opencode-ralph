#!/bin/bash
set -euo pipefail

# ─────────────────────────────────────────────────────────────────────────────
# Ralph — Autonomous OpenCode agent with an interactive TUI
#
#   No arguments  → interactive TUI (requires gum)
#   With a prompt → direct CLI mode (original behavior, no gum required)
#
# See: ralph --help
# ─────────────────────────────────────────────────────────────────────────────

# ─── Constants ──────────────────────────────────────────────────────────────────

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENT_FILE="$SCRIPT_DIR/ralph.md"
RALPH_DIR="${RALPH_HOME:-$HOME/.ralph}"
SESSIONS_DIR="$RALPH_DIR/sessions"
CONFIG_FILE="$RALPH_DIR/config"
OC_AGENTS_DIR="$HOME/.config/opencode/agents"
DONE_TOKEN="<ralph>DONE</ralph>"
GREEN="#00E540"

# Globals set by load_config / CLI flags
DEFAULT_MODEL="${RALPH_MODEL:-}"
DEFAULT_THINKING="off"
DEFAULT_MAX_ITER="${RALPH_MAX_ITER:-50}"

# Temp agent file tracking (cleaned up on exit)
_TMP_AGENT_FILE=""
_AGENT_NAME="ralph"

# ─── Cleanup ────────────────────────────────────────────────────────────────────

cleanup() {
  if [[ -n "$_TMP_AGENT_FILE" && -f "$_TMP_AGENT_FILE" ]]; then
    rm -f "$_TMP_AGENT_FILE"
  fi
}
trap cleanup EXIT INT TERM

# ─── Config Management ─────────────────────────────────────────────────────────

load_config() {
  mkdir -p "$RALPH_DIR"
  if [[ -f "$CONFIG_FILE" ]]; then
    # shellcheck source=/dev/null
    source "$CONFIG_FILE" 2>/dev/null || true
  fi
}

save_config() {
  mkdir -p "$RALPH_DIR"
  cat > "$CONFIG_FILE" <<EOF
DEFAULT_MODEL="$DEFAULT_MODEL"
DEFAULT_THINKING="$DEFAULT_THINKING"
DEFAULT_MAX_ITER="$DEFAULT_MAX_ITER"
EOF
}

# ─── Dependency Check ───────────────────────────────────────────────────────────

has_gum() { command -v gum &>/dev/null; }

ensure_gum() {
  if has_gum; then return 0; fi

  echo ""
  echo "Ralph TUI requires 'gum' by Charmbracelet."
  echo "  https://github.com/charmbracelet/gum"
  echo ""

  local -a cmds=() labels=()

  if command -v brew &>/dev/null; then
    cmds+=("brew install gum")
    labels+=("Homebrew:  brew install gum")
  fi
  if command -v go &>/dev/null; then
    cmds+=("go install github.com/charmbracelet/gum@latest")
    labels+=("Go:        go install github.com/charmbracelet/gum@latest")
  fi
  if command -v pacman &>/dev/null; then
    cmds+=("sudo pacman -S gum")
    labels+=("pacman:    sudo pacman -S gum")
  fi
  if command -v apt-get &>/dev/null; then
    cmds+=("sudo mkdir -p /etc/apt/keyrings && curl -fsSL https://repo.charm.sh/apt/gpg.key | sudo gpg --dearmor -o /etc/apt/keyrings/charm.gpg && echo 'deb [signed-by=/etc/apt/keyrings/charm.gpg] https://repo.charm.sh/apt/ * *' | sudo tee /etc/apt/sources.list.d/charm.list >/dev/null && sudo apt-get update && sudo apt-get install -y gum")
    labels+=("apt:       (adds Charm repo & installs)")
  fi
  if command -v nix-env &>/dev/null; then
    cmds+=("nix-env -iA nixpkgs.gum")
    labels+=("Nix:       nix-env -iA nixpkgs.gum")
  fi

  if [[ ${#cmds[@]} -eq 0 ]]; then
    echo "No supported package manager detected."
    echo "Install gum manually: https://github.com/charmbracelet/gum#installation"
    exit 1
  fi

  echo "Available installers:"
  for i in "${!labels[@]}"; do
    echo "  $((i + 1)). ${labels[$i]}"
  done
  echo "  0. Cancel"
  echo ""
  read -rp "Install gum? [1]: " choice
  choice="${choice:-1}"

  if [[ "$choice" == "0" ]]; then
    echo "Cannot run the TUI without gum."
    exit 1
  fi

  local idx=$((choice - 1))
  if [[ $idx -lt 0 || $idx -ge ${#cmds[@]} ]]; then
    echo "Invalid choice."
    exit 1
  fi

  echo ""
  echo "Running: ${cmds[$idx]}"
  eval "${cmds[$idx]}"

  if ! has_gum; then
    echo ""
    echo "Installation failed. Install gum manually:"
    echo "  https://github.com/charmbracelet/gum#installation"
    exit 1
  fi

  echo ""
  echo "gum installed successfully!"
  echo ""
}

# ─── Agent File Generation (thinking support) ──────────────────────────────────

# Extract the markdown body from ralph.md (everything after the second ---)
_agent_body() {
  awk 'BEGIN{n=0} /^---[[:space:]]*$/{n++; next} n>=2{print}' "$AGENT_FILE"
}

# Set up the agent for a run. Sets two globals:
#   _AGENT_NAME     — the agent name to pass to --agent
#   _TMP_AGENT_FILE — path to the temp agent file (empty if none)
#
# IMPORTANT: Do NOT call this in a subshell (e.g. $(setup_agent ...)).
# The globals won't propagate. Call it directly and read _AGENT_NAME after.
setup_agent() {
  local model="$1" thinking="$2"

  _AGENT_NAME="ralph"
  _TMP_AGENT_FILE=""

  # No thinking → use the standard agent file as-is
  if [[ "$thinking" == "off" ]]; then
    return
  fi

  local provider="${model%%/*}"
  local thinking_yaml=""

  case "$provider" in
    anthropic)
      local budget
      case "$thinking" in
        low)  budget=8000  ;;
        high) budget=16000 ;;
        max)  budget=32000 ;;
        *)    budget=16000 ;;
      esac
      thinking_yaml=$(cat <<YAML
thinking:
  type: enabled
  budgetTokens: $budget
YAML
      )
      ;;

    openai)
      local effort
      case "$thinking" in
        low)  effort="low"    ;;
        high) effort="high"   ;;
        max)  effort="high"   ;;
        *)    effort="medium" ;;
      esac
      thinking_yaml="reasoningEffort: $effort"
      ;;

    google)
      local budget
      case "$thinking" in
        low)      budget=8000  ;;
        high|max) budget=16000 ;;
        *)        budget=8000  ;;
      esac
      thinking_yaml=$(cat <<YAML
thinkingConfig:
  thinkingBudget: $budget
YAML
      )
      ;;

    *)
      # Unknown provider — thinking not supported, fall back to standard agent
      return
      ;;
  esac

  # Create a temp agent in the OpenCode agents directory
  local tmp_name="ralph-tmp-$$"
  mkdir -p "$OC_AGENTS_DIR"
  _TMP_AGENT_FILE="$OC_AGENTS_DIR/${tmp_name}.md"
  _AGENT_NAME="$tmp_name"

  local body
  body=$(_agent_body)

  cat > "$_TMP_AGENT_FILE" <<AGENT
---
description: Autonomous agent that works until the task is fully complete, narrated in Ralph Wiggum's voice
mode: primary
temperature: 0.7
color: "$GREEN"
$thinking_yaml
permission:
  edit: allow
  bash:
    "*": allow
  webfetch: allow
---
$body
AGENT
}

# Remove the temp agent file if it exists
_cleanup_tmp_agent() {
  if [[ -n "$_TMP_AGENT_FILE" && -f "$_TMP_AGENT_FILE" ]]; then
    rm -f "$_TMP_AGENT_FILE"
    _TMP_AGENT_FILE=""
  fi
}

# ─── Session Storage ────────────────────────────────────────────────────────────

save_session_meta() {
  local session_id="$1" model="$2" thinking="$3" max_iter="$4"
  local prompt="$5" status="$6" iterations="$7"

  # Replace newlines in prompt with spaces for the meta file
  local safe_prompt="${prompt//$'\n'/ }"

  mkdir -p "$SESSIONS_DIR"
  cat > "$SESSIONS_DIR/${session_id}.meta" <<META
timestamp=$session_id
model=$model
thinking=$thinking
max_iter=$max_iter
prompt=$safe_prompt
status=$status
iterations=$iterations
META
}

# Format a session meta file into a single display line
_session_line() {
  local meta="$1"
  local ts model prompt status thinking iterations

  ts=$(grep '^timestamp=' "$meta" | cut -d= -f2)
  model=$(grep '^model=' "$meta" | cut -d= -f2)
  prompt=$(grep '^prompt=' "$meta" | cut -d= -f2-)
  status=$(grep '^status=' "$meta" | cut -d= -f2)
  thinking=$(grep '^thinking=' "$meta" | cut -d= -f2)

  local icon
  case "$status" in
    complete)   icon="+" ;;
    incomplete) icon="~" ;;
    *)          icon="x" ;;
  esac

  local short="${prompt:0:40}"
  [[ ${#prompt} -gt 40 ]] && short="${short}..."

  echo "$icon $ts | $model | T:$thinking | $short"
}

# ─── Core Run Loop ─────────────────────────────────────────────────────────────

# Runs the ralph agent loop. Works in both TUI and CLI mode (plain echo only).
# Arguments: model thinking max_iter prompt
run_session() {
  local model="$1" thinking="$2" max_iter="$3" prompt="$4"

  local session_id
  session_id=$(date +%Y-%m-%d_%H%M%S)
  local log_file="$SESSIONS_DIR/${session_id}.log"
  mkdir -p "$SESSIONS_DIR"

  # Set up the agent (may create a temp file for thinking)
  setup_agent "$model" "$thinking"

  echo ""
  echo "  Model:    $model"
  echo "  Thinking: $thinking"
  echo "  Max iter: $max_iter"
  echo ""

  local iterations=0
  local status="incomplete"

  for i in $(seq 1 "$max_iter"); do
    iterations=$i

    echo ""
    echo "========================================"
    echo "[ralph] iteration $i / $max_iter"
    echo "========================================"
    echo ""

    local iter_prompt
    if [[ "$i" -eq 1 ]]; then
      iter_prompt="$prompt"
    else
      iter_prompt="Continue working on the following task. Check the current state of the codebase and pick up where you left off: $prompt"
    fi

    local output
    output=$(opencode run --agent "$_AGENT_NAME" --model "$model" "$iter_prompt" 2>&1 \
      | tee /dev/tty \
      | tee -a "$log_file") || true

    if echo "$output" | grep -qF "$DONE_TOKEN"; then
      status="complete"
      echo ""
      echo "========================================"
      echo "[ralph] Task complete on iteration $i."
      echo "========================================"
      break
    fi
  done

  if [[ "$status" != "complete" ]]; then
    echo ""
    echo "========================================"
    echo "[ralph] Hit max iterations ($max_iter) without completion token."
    echo "[ralph] The agent may not have finished. Re-run or increase --max-iter."
    echo "========================================"
  fi

  save_session_meta "$session_id" "$model" "$thinking" "$max_iter" "$prompt" "$status" "$iterations"
  _cleanup_tmp_agent

  echo ""
  echo "[ralph] Session saved: $session_id"
}

# ─── Model Selection (TUI helper) ──────────────────────────────────────────────

_select_model() {
  local current="${1:-}"

  # Try to get model list from opencode
  local raw
  raw=$(opencode models 2>/dev/null || true)

  # Extract strings that look like model IDs (provider/model-name)
  local models
  models=$(echo "$raw" | grep -oE '[a-zA-Z0-9_-]+/[a-zA-Z0-9._-]+' | sort -u || true)

  if [[ -n "$models" ]]; then
    echo "$models" | gum filter --placeholder "Type to search models..." --height 15 --value "$current"
  else
    gum input --placeholder "provider/model-id (e.g. anthropic/claude-sonnet-4-20250514)" \
      --value "$current" --prompt "> "
  fi
}

# ─── TUI Screens ───────────────────────────────────────────────────────────────

_show_banner() {
  gum style \
    --foreground "$GREEN" --bold \
    --align center --width 44 \
    --margin "1 0" --padding "0 1" \
    '╔════════════════════════════════════════╗' \
    '║                                        ║' \
    '║              R A L P H                 ║' \
    '║          "Im helping!"                 ║' \
    '║                                        ║' \
    '╚════════════════════════════════════════╝'
}

_new_session_ui() {
  # 1. Model
  echo ""
  gum style --foreground "$GREEN" --bold "  Select a model"
  local model
  model=$(_select_model "${DEFAULT_MODEL:-}") || return
  if [[ -z "$model" ]]; then
    gum style --foreground 196 "  No model selected."
    sleep 1
    return
  fi

  # 2. Thinking
  echo ""
  gum style --foreground "$GREEN" --bold "  Select thinking level"
  local thinking
  thinking=$(gum choose --selected "${DEFAULT_THINKING:-off}" \
    "off" "low" "high" "max") || return

  # 3. Max iterations
  echo ""
  local max_iter
  max_iter=$(gum input --placeholder "50" \
    --value "${DEFAULT_MAX_ITER:-50}" \
    --prompt "Max iterations: " --width 20) || return
  max_iter="${max_iter:-50}"

  # 4. Prompt
  echo ""
  gum style --foreground "$GREEN" --bold "  Enter your prompt"
  local prompt
  prompt=$(gum write --placeholder "What should Ralph work on?" \
    --char-limit 0 --width 80 --height 6) || return
  if [[ -z "$prompt" ]]; then
    gum style --foreground 196 "  No prompt entered."
    sleep 1
    return
  fi

  # 5. Confirm
  echo ""
  gum style \
    --border double --border-foreground "$GREEN" \
    --padding "0 1" --margin "0 2" \
    "Model:      $model" \
    "Thinking:   $thinking" \
    "Max iter:   $max_iter" \
    "" \
    "Prompt:" \
    "$prompt"
  echo ""

  if ! gum confirm "Start session?"; then
    return
  fi

  run_session "$model" "$thinking" "$max_iter" "$prompt"

  echo ""
  read -rp "Press Enter to continue..."
}

_sessions_ui() {
  if [[ ! -d "$SESSIONS_DIR" ]]; then
    gum style --foreground 208 "  No sessions yet."
    sleep 1.5
    return
  fi

  local -a metas=()
  while IFS= read -r f; do
    [[ -n "$f" ]] && metas+=("$f")
  done < <(ls -t "$SESSIONS_DIR"/*.meta 2>/dev/null || true)

  if [[ ${#metas[@]} -eq 0 ]]; then
    gum style --foreground 208 "  No sessions yet."
    sleep 1.5
    return
  fi

  # Build display lines
  local -a lines=()
  for m in "${metas[@]}"; do
    lines+=("$(_session_line "$m")")
  done

  local selected
  selected=$(printf '%s\n' "${lines[@]}" \
    | gum filter --placeholder "Search sessions..." --height 15) || return

  # Extract the timestamp from the selected line (second field)
  local ts
  ts=$(echo "$selected" | awk -F'|' '{print $1}' | sed 's/^[^ ]* *//' | xargs)

  local meta_file="$SESSIONS_DIR/${ts}.meta"
  local log_file="$SESSIONS_DIR/${ts}.log"

  if [[ ! -f "$meta_file" ]]; then
    gum style --foreground 196 "  Session not found."
    sleep 1
    return
  fi

  # Show meta and offer actions
  echo ""
  gum style --border normal --border-foreground "$GREEN" --padding "0 1" \
    "$(cat "$meta_file")"
  echo ""

  local action
  action=$(gum choose "View log" "Re-run (same settings)" "Back") || return

  case "$action" in
    "View log")
      if [[ -f "$log_file" ]]; then
        gum pager < "$log_file"
      else
        gum style --foreground 208 "  No log file for this session."
        sleep 1
      fi
      ;;
    "Re-run"*)
      local model thinking max_iter prompt
      model=$(grep '^model=' "$meta_file" | cut -d= -f2)
      thinking=$(grep '^thinking=' "$meta_file" | cut -d= -f2)
      max_iter=$(grep '^max_iter=' "$meta_file" | cut -d= -f2)
      prompt=$(grep '^prompt=' "$meta_file" | cut -d= -f2-)

      run_session "$model" "$thinking" "$max_iter" "$prompt"

      echo ""
      read -rp "Press Enter to continue..."
      ;;
  esac
}

_settings_ui() {
  while true; do
    clear
    gum style --foreground "$GREEN" --bold --margin "1 0" "  Settings"
    echo ""

    local choice
    choice=$(gum choose \
      "Default model:          ${DEFAULT_MODEL:-<not set>}" \
      "Default thinking:       $DEFAULT_THINKING" \
      "Default max iterations: $DEFAULT_MAX_ITER" \
      "" \
      "Save & back") || return

    case "$choice" in
      "Default model"*)
        DEFAULT_MODEL=$(_select_model "${DEFAULT_MODEL:-}") || true
        ;;
      "Default thinking"*)
        DEFAULT_THINKING=$(gum choose --selected "$DEFAULT_THINKING" \
          "off" "low" "high" "max") || true
        ;;
      "Default max"*)
        DEFAULT_MAX_ITER=$(gum input --placeholder "50" \
          --value "$DEFAULT_MAX_ITER" --prompt "Max iterations: ") || true
        ;;
      "Save & back")
        save_config
        echo ""
        gum style --foreground "$GREEN" "  Settings saved to $CONFIG_FILE"
        sleep 1
        return
        ;;
    esac
  done
}

_menu_loop() {
  ensure_gum
  load_config

  while true; do
    clear
    _show_banner

    local choice
    choice=$(gum choose \
      "New Session" \
      "Recent Sessions" \
      "Settings" \
      "Quit") || exit 0

    case "$choice" in
      "New Session")      _new_session_ui ;;
      "Recent Sessions")  _sessions_ui ;;
      "Settings")         _settings_ui ;;
      "Quit")             exit 0 ;;
    esac
  done
}

# ─── CLI Usage ──────────────────────────────────────────────────────────────────

usage() {
  cat <<'USAGE'
Usage: ralph [options] [prompt]

Autonomous OpenCode agent narrated by Ralph Wiggum.

With no arguments, opens the interactive TUI (requires gum).
With a prompt, runs directly in the terminal.

Options:
  -m, --model <provider/model>   Model to use (or set RALPH_MODEL env var)
  --thinking <off|low|high|max>  Thinking / reasoning level (default: off)
  --max-iter <n>                 Max loop iterations (default: 50, or RALPH_MAX_ITER)
  --once                         Run a single invocation without looping
  --tui                          Open the interactive TUI
  -h, --help                     Show this help message

Examples:
  ralph                                             # interactive TUI
  ralph "Fix all failing E2E tests"                 # direct mode
  ralph -m anthropic/claude-sonnet-4-20250514 "Refactor auth"
  ralph --thinking high "Solve this complex bug"
  ralph --max-iter 5 "Add input validation"
  ralph --once "Explain the auth flow"

Setup:
  Copy or symlink ralph.md into your OpenCode agents directory:
    cp ralph.md ~/.config/opencode/agents/ralph.md   # global
    cp ralph.md .opencode/agents/ralph.md            # per-project

  Install gum for the TUI (optional, only needed for interactive mode):
    brew install gum                                 # macOS / Homebrew
    go install github.com/charmbracelet/gum@latest   # Go
USAGE
}

# ─── Entrypoint ─────────────────────────────────────────────────────────────────

# No arguments → TUI mode
if [[ $# -eq 0 ]]; then
  _menu_loop
  exit 0
fi

# Parse CLI arguments
MODEL="${RALPH_MODEL:-}"
THINKING="off"
MAX_ITER="${RALPH_MAX_ITER:-50}"
ONCE=false
PROMPT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--model)
      MODEL="$2"
      shift 2
      ;;
    --thinking)
      THINKING="$2"
      shift 2
      ;;
    --max-iter)
      MAX_ITER="$2"
      shift 2
      ;;
    --once)
      ONCE=true
      shift
      ;;
    --tui)
      _menu_loop
      exit 0
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      PROMPT="$*"
      break
      ;;
  esac
done

if [[ -z "$PROMPT" ]]; then
  echo "Error: No prompt provided."
  echo ""
  usage
  exit 1
fi

# Interactive model selection if none specified (CLI fallback, no gum needed)
if [[ -z "$MODEL" ]]; then
  echo "No model specified. Use -m or set RALPH_MODEL."
  echo ""
  echo "Available models:"
  opencode models 2>/dev/null || echo "  (could not list models — is opencode installed?)"
  echo ""
  read -rp "Model (provider/model-id): " MODEL
  if [[ -z "$MODEL" ]]; then
    echo "Error: No model selected."
    exit 1
  fi
fi

# Single-run mode
if [[ "$ONCE" == true ]]; then
  load_config
  setup_agent "$MODEL" "$THINKING"
  exec opencode run --agent "$_AGENT_NAME" --model "$MODEL" "$PROMPT"
fi

# Loop mode (with session tracking)
load_config
run_session "$MODEL" "$THINKING" "$MAX_ITER" "$PROMPT"
