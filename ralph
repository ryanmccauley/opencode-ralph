#!/bin/bash
set -euo pipefail

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
AGENT_FILE="$SCRIPT_DIR/ralph.md"

DONE_TOKEN="<ralph>DONE</ralph>"

usage() {
  echo "Usage: ralph [options] <prompt>"
  echo ""
  echo "Run OpenCode with the Ralph Wiggum autonomous agent."
  echo ""
  echo "Ralph loops automatically, re-invoking the agent until it outputs"
  echo "the completion token ($DONE_TOKEN) or hits the max iteration limit."
  echo ""
  echo "Options:"
  echo "  -m, --model <provider/model>      Model to use (or set RALPH_MODEL env var)"
  echo "  --max-iter <n>                     Max loop iterations (default: 50, or RALPH_MAX_ITER)"
  echo "  --once                             Run once without looping (single invocation)"
  echo "  -h, --help                         Show this help message"
  echo ""
  echo "Examples:"
  echo "  ralph \"Fix all failing E2E tests until they pass\""
  echo "  ralph -m anthropic/claude-sonnet-4-20250514 \"Refactor the auth module\""
  echo "  ralph --max-iter 5 \"Add input validation to the API\""
  echo "  ralph --once \"Explain the auth flow\""
  echo "  RALPH_MODEL=openai/gpt-4.1 ralph \"Add unit tests for the API layer\""
  echo ""
  echo "Setup:"
  echo "  Copy or symlink ralph.md into your OpenCode agents directory:"
  echo "    cp ralph.md ~/.config/opencode/agents/ralph.md   # global"
  echo "    cp ralph.md .opencode/agents/ralph.md            # per-project"
}

MODEL="${RALPH_MODEL:-}"
MAX_ITER="${RALPH_MAX_ITER:-50}"
ONCE=false
PROMPT=""

while [[ $# -gt 0 ]]; do
  case "$1" in
    -m|--model)
      MODEL="$2"
      shift 2
      ;;
    --max-iter)
      MAX_ITER="$2"
      shift 2
      ;;
    --once)
      ONCE=true
      shift
      ;;
    -h|--help)
      usage
      exit 0
      ;;
    *)
      PROMPT="$*"
      break
      ;;
  esac
done

if [ -z "$PROMPT" ]; then
  echo "Error: No prompt provided."
  echo ""
  usage
  exit 1
fi

if [ -z "$MODEL" ]; then
  echo "No model specified. Use -m or set RALPH_MODEL."
  echo ""
  echo "Available models:"
  opencode models 2>/dev/null || echo "  (could not list models -- is opencode installed?)"
  echo ""
  read -rp "Model (provider/model-id): " MODEL
  if [ -z "$MODEL" ]; then
    echo "Error: No model selected."
    exit 1
  fi
fi

# Single-run mode: no loop, just exec
if [ "$ONCE" = true ]; then
  exec opencode run --agent ralph --model "$MODEL" "$PROMPT"
fi

# Loop mode: keep re-invoking until the agent signals completion
for i in $(seq 1 "$MAX_ITER"); do
  echo ""
  echo "========================================"
  echo "[ralph] iteration $i / $MAX_ITER"
  echo "========================================"
  echo ""

  # Build the prompt: on iteration 2+ tell the agent to continue
  if [ "$i" -eq 1 ]; then
    ITER_PROMPT="$PROMPT"
  else
    ITER_PROMPT="Continue working on the following task. Check the current state of the codebase and pick up where you left off: $PROMPT"
  fi

  # Run the agent, stream output to terminal and capture it for token detection
  OUTPUT=$(opencode run --agent ralph --model "$MODEL" "$ITER_PROMPT" 2>&1 | tee /dev/tty) || true

  # Check for the completion token
  if echo "$OUTPUT" | grep -qF "$DONE_TOKEN"; then
    echo ""
    echo "========================================"
    echo "[ralph] Task complete on iteration $i."
    echo "========================================"
    exit 0
  fi
done

echo ""
echo "========================================"
echo "[ralph] Hit max iterations ($MAX_ITER) without completion token."
echo "[ralph] The agent may not have finished. Re-run or increase --max-iter."
echo "========================================"
exit 1
