    "test:watch": "bun test --watch"
  },
  "dependencies": {
    "@clack/prompts": "^1.2.0",
    "@opencode-ai/sdk": "^1.4.0",
    "fuse.js": "^7.0.0"
  },
  "devDependencies": {
    "bun-types": "^1.3.11",
    "typescript": "^6.0.2"
  }
}
